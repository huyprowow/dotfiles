#!/bin/bash

THEME="custom_theme"
SRC="$HOME/dotfiles/sddm/themes/$THEME"
DST="/usr/share/sddm/themes/$THEME"

if [ ! -d "$SRC" ]; then
  echo "Source theme not found!"
  exit 1
fi

sudo mkdir -p "$DST"

if sudo rsync -a --delete "$SRC/" "$DST/"; then
  sudo chown -R root:root "$DST"
  sudo chmod -R 755 "$DST"
  echo "✔ Theme deployed successfully to $DST"
else
  echo "✘ Deploy failed"
fi
